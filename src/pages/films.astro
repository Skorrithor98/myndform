---
import Layout from '../layouts/Layout.astro';
import { client, urlFor } from '../sanityClient.js';

const films = await client.fetch(`*[_type == "film"] | order(releaseDate asc)`);
const nowFilms = films.filter(f => f.status === 'now');
const soonFilms = films.filter(f => f.status === 'soon');
const archiveFilms = films.filter(f => f.status === 'archive');
---

<Layout title="Kvikmyndadreifing">
  <div class="film-hero">
    <div class="film-hero-eyebrow">Myndform · Kvikmyndadreifing</div>
    <h1>Kvikmyndir</h1>
  </div>

  <div class="film-tabs">
    <button class="tab active" data-tab="now">Í bíó núna</button>
    <button class="tab" data-tab="soon">Væntanlegt</button>
    <button class="tab" data-tab="archive">Eldri myndir</button>
  </div>

  <div id="tab-now" class="tab-content section">
    <div class="film-grid">
      {nowFilms.map(film => (
        <div class="film-card">
          <div class="film-card-poster">
  {film.poster && <img src={urlFor(film.poster).width(600).url()} alt={film.title} />}
</div>
          <div class="film-badge badge-now">Í bíó</div>
          <div class="film-card-title">{film.title}</div>
          <div class="film-card-date">{film.releaseDate}</div>
        </div>
      ))}
    </div>
  </div>

  <div id="tab-soon" class="tab-content section" style="display:none">
  <div class="film-grid">
    {soonFilms.map(film => (
      <div class="film-card">
        <div class="film-card-poster">
          {film.poster && <img src={urlFor(film.poster).width(600).url()} alt={film.title} />}
        </div>
        <div class="film-badge badge-soon">{film.releaseDate}</div>
        <div class="film-card-title">{film.title}</div>
        <div class="film-card-date">{film.releaseDate}</div>
      </div>
    ))}
  </div>
</div>

  <div id="tab-archive" class="tab-content section" style="display:none">
  <div class="film-grid">
    {archiveFilms.map(film => (
      <div class="film-card">
        <div class="film-card-poster">
          {film.poster && <img src={urlFor(film.poster).width(600).url()} alt={film.title} />}
        </div>
        <div class="film-card-title">{film.title}</div>
        <div class="film-card-date">{film.releaseDate}</div>
      </div>
    ))}
  </div>
</div>
</Layout>

<style>
  .film-hero {
    background: var(--black);
    padding: 56px 32px 48px;
  }
  .film-hero-eyebrow {
    font-size: 11px; font-weight: 600; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--red); margin-bottom: 12px;
  }
  h1 {
    font-size: 38px; font-weight: 700; color: var(--white);
    letter-spacing: -0.02em;
  }
  .film-tabs {
    display: flex; border-bottom: 1px solid var(--gray-20);
    padding: 0 32px; background: var(--white);
    position: sticky; top: 56px; z-index: 9;
  }
  .tab {
    padding: 14px 20px; font-size: 13px; font-weight: 500;
    color: var(--gray-60); cursor: pointer;
    border: none; background: none;
    border-bottom: 2px solid transparent;
    transition: color 0.15s, border-color 0.15s;
    margin-bottom: -1px; font-family: var(--font);
  }
  .tab:hover { color: var(--black); }
  .tab.active { color: var(--red); border-bottom-color: var(--red); }
  .section { padding: 40px 32px; }
  .film-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  .film-card { cursor: pointer; }
  .film-card-poster {
  aspect-ratio: 2/3; border-radius: 6px;
  overflow: hidden; position: relative;
  margin-bottom: 10px;
  background: #1a1a1a;
}
.film-card-poster img {
  width: 100%; height: 100%;
  object-fit: cover; display: block;
}
  .film-badge {
    display: inline-block; font-size: 10px; font-weight: 600;
    letter-spacing: 0.08em; text-transform: uppercase;
    padding: 3px 7px; border-radius: 3px; margin-bottom: 6px;
  }
  .badge-now { background: var(--red); color: #fff; }
  .badge-soon { background: var(--gray-10); color: var(--gray-60); }
  .film-card-title { font-size: 13px; font-weight: 600; margin-bottom: 2px; line-height: 1.3; }
  .film-card-date { font-size: 12px; color: var(--gray-60); }

  .p1 { background: linear-gradient(145deg, #2d1545, #0e0820); }
  .p2 { background: linear-gradient(145deg, #1a2d10, #081508); }
  .p3 { background: linear-gradient(145deg, #3a1515, #180808); }
  .p4 { background: linear-gradient(145deg, #102535, #081218); }
  .p5 { background: linear-gradient(145deg, #2a2010, #130f08); }
  .p6 { background: linear-gradient(145deg, #1a1535, #0c0a18); }
  .p7 { background: linear-gradient(145deg, #252510, #101008); }
  .p8 { background: linear-gradient(145deg, #301020, #180810); }

  @media (max-width: 700px) {
    .film-grid { grid-template-columns: repeat(2, 1fr); }
    .section { padding: 32px 20px; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.tab').forEach(tab => {
      tab.addEventListener('click', () => {
        const tabId = tab.getAttribute('data-tab');
        document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        document.querySelectorAll('.tab-content').forEach(t => t.style.display = 'none');
        document.getElementById('tab-' + tabId).style.display = 'block';
      });
    });
  });
</script>