---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Kvikmyndadreifing">
  <div class="film-hero">
    <div class="film-hero-eyebrow">Myndform · Kvikmyndadreifing</div>
    <h1>Kvikmyndir</h1>
  </div>

  <div class="film-tabs">
    <button class="tab active" data-tab="now">Í bíó núna</button>
    <button class="tab" data-tab="soon">Væntanlegt</button>
    <button class="tab" data-tab="archive">Eldri myndir</button>
  </div>

  <div id="tab-now" class="tab-content section">
    <div class="film-grid" id="grid-now"></div>
  </div>

  <div id="tab-soon" class="tab-content section" style="display:none">
    <div class="film-grid" id="grid-soon"></div>
  </div>

  <div id="tab-archive" class="tab-content section" style="display:none">
    <div class="film-grid" id="grid-archive"></div>
  </div>
</Layout>

<style>
  .film-hero {
    background: var(--black);
    padding: 56px 32px 48px;
  }
  .film-hero-eyebrow {
    font-size: 11px; font-weight: 600; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--red); margin-bottom: 12px;
  }
  h1 {
    font-size: 38px; font-weight: 700; color: var(--white);
    letter-spacing: -0.02em;
  }
  .film-tabs {
    display: flex; border-bottom: 1px solid var(--gray-20);
    padding: 0 32px; background: var(--white);
    position: sticky; top: 56px; z-index: 9;
  }
  .tab {
    padding: 14px 20px; font-size: 13px; font-weight: 500;
    color: var(--gray-60); cursor: pointer;
    border: none; background: none;
    border-bottom: 2px solid transparent;
    transition: color 0.15s, border-color 0.15s;
    margin-bottom: -1px; font-family: var(--font);
  }
  .tab:hover { color: var(--black); }
  .tab.active { color: var(--red); border-bottom-color: var(--red); }

  .section {
    padding: 40px 32px;
  }

  .film-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 24px 14px;
    width: 100%;
  }

  /* The film cards are built by the script below, so Astro's normal
     scoped styles don't reach them. :global() lets these rules apply. */

  .film-grid :global(.film-card) {
    cursor: pointer;
    min-width: 0;
    overflow: hidden;
    width: 100%;
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .film-grid :global(.poster-wrap) {
    width: 100%;
    aspect-ratio: 2 / 3;
    border-radius: 6px;
    overflow: hidden;
    background: #1a1a1a;
    margin-bottom: 10px;
    position: relative;
  }

  .film-grid :global(.poster-wrap img) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .film-grid :global(.film-badge) {
    display: inline-block;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 3px 7px;
    border-radius: 3px;
    margin-bottom: 6px;
  }
  .film-grid :global(.badge-now)  { background: var(--red); color: #fff; }
  .film-grid :global(.badge-soon) { background: var(--gray-10); color: var(--gray-60); }
  .film-grid :global(.film-title) { font-size: 13px; font-weight: 600; margin-bottom: 2px; line-height: 1.3; }
  .film-grid :global(.film-date)  { font-size: 12px; color: var(--gray-60); }

  @media (max-width: 1100px) { .film-grid { grid-template-columns: repeat(4, 1fr); } }
  @media (max-width: 900px)  { .film-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 700px)  {
    .film-grid { grid-template-columns: repeat(2, 1fr); }
    .section { padding: 32px 20px; }
  }
  @media (max-width: 480px)  { .film-grid { grid-template-columns: repeat(2, 1fr); } }
</style>

<script>
  var PID = 'dc8pwssq';
  var DS = 'production';
  var Q = encodeURIComponent('*[_type == "film"] | order(releaseDate asc)');
  var API = 'https://' + PID + '.api.sanity.io/v2024-01-01/data/query/' + DS + '?query=' + Q;

  function imgUrl(ref) {
    var id = ref.asset._ref.replace('image-', '').replace(/-([a-z]+)$/, '.$1');
    return 'https://cdn.sanity.io/images/' + PID + '/' + DS + '/' + id + '?w=400';
  }

  function fmtDate(s) {
    return new Date(s).toLocaleDateString('is-IS', {day:'numeric', month:'long', year:'numeric'});
  }

  function makeCard(film, badgeClass, badgeText) {
    var inner =
      '<div class="poster-wrap">' +
        (film.poster ? '<img src="' + imgUrl(film.poster) + '" alt="' + film.title + '">' : '') +
      '</div>' +
      '<span class="film-badge ' + badgeClass + '">' + badgeText + '</span>' +
      '<div class="film-title">' + film.title + '</div>' +
      '<div class="film-date">' + fmtDate(film.releaseDate) + '</div>';

    var el;
    if (film.slug && film.slug.current) {
      el = document.createElement('a');
      el.href = '/kvikmynd?slug=' + film.slug.current;
    } else {
      el = document.createElement('div');
    }
    el.className = 'film-card';
    el.innerHTML = inner;
    return el;
  }

  fetch(API)
    .then(function(r) { return r.json(); })
    .then(function(data) {
      var films = data.result;
      var gNow = document.getElementById('grid-now');
      var gSoon = document.getElementById('grid-soon');
      var gArch = document.getElementById('grid-archive');
      films.forEach(function(f) {
        if (f.status === 'now') gNow.appendChild(makeCard(f, 'badge-now', 'Í bíó'));
        else if (f.status === 'soon') gSoon.appendChild(makeCard(f, 'badge-soon', 'Væntanlegt'));
        else if (f.status === 'archive') gArch.appendChild(makeCard(f, 'badge-soon', 'Eldri mynd'));
      });
    });

  document.querySelectorAll('.tab').forEach(function(tab) {
    tab.addEventListener('click', function() {
      var id = tab.getAttribute('data-tab');
      document.querySelectorAll('.tab').forEach(function(t) { t.classList.remove('active'); });
      tab.classList.add('active');
      document.querySelectorAll('.tab-content').forEach(function(t) { t.style.display = 'none'; });
      document.getElementById('tab-' + id).style.display = 'block';
    });
  });
</script>