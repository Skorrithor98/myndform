---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Celsius">
  <div class="site-hero">
    <div class="site-hero-eyebrow">Heildsala</div>
    <h1>Celsius</h1>
    <div class="site-hero-actions">
      <a href="mailto:myndform@myndform.is?subject=Fyrirspurn%20um%20Celsius" class="site-hero-btn">Hafðu samband til að panta</a>
    </div>
  </div>

  <div class="content">
    <p class="page-intro">Orkudrykkurinn Celsius — ferskar bragðtegundir í heildsölu. Smelltu á bragðtegund til að sjá nánar, eða hafðu samband til að panta.</p>
    <div id="flavours-root" class="flavour-grid"><p class="loading">Sæki bragðtegundir…</p></div>
  </div>
</Layout>

<style>
  .content { padding: 48px 48px 80px; }
  .loading { font-size: 14px; color: var(--gray-60); }

  .page-intro {
    font-size: 23px; color: var(--black); line-height: 1.5;
    max-width: 720px; margin: 0 0 52px;
    font-weight: 500; letter-spacing: -0.01em;
    padding-left: 22px; border-left: 3px solid var(--red);
  }

  :global(.flavour-grid) { display: grid; grid-template-columns: repeat(5, 1fr); gap: 20px; }
  :global(.flavour-grid .empty-note) { font-size: 14px; color: var(--gray-60); grid-column: 1 / -1; }

  :global(.flavour-card) {
    position: relative;
    border-radius: 14px; overflow: hidden;
    border: 1px solid var(--gray-20);
    background: #fff; display: block;
    text-decoration: none; color: inherit;
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }
  :global(.flavour-card:hover) { transform: translateY(-4px); box-shadow: 0 12px 30px rgba(0,0,0,0.12); }
  :global(.flavour-accent) { height: 6px; width: 100%; background: var(--gray-20); }
  :global(.flavour-photo) {
    height: 300px; display: flex; align-items: center; justify-content: center;
    padding: 20px; background: #fff; overflow: hidden;
  }
  :global(.flavour-card img) {
    max-width: 100% !important; max-height: 100% !important;
    width: auto !important; height: auto !important;
    object-fit: contain; display: block;
  }
  :global(.flavour-meta) { padding: 14px 18px 20px; border-top: 1px solid var(--gray-20); }
  :global(.flavour-name) { font-size: 15px; font-weight: 700; color: #111; line-height: 1.3; }
  :global(.flavour-tag) {
    position: absolute; top: 14px; right: 14px; z-index: 2;
    background: var(--red); color: #fff;
    font-size: 11px; font-weight: 600; letter-spacing: 0.04em;
    padding: 5px 11px; border-radius: 6px;
    opacity: 0; transform: translateY(-4px);
    transition: opacity 0.18s ease, transform 0.18s ease;
    pointer-events: none;
  }
  :global(.flavour-card:hover .flavour-tag) { opacity: 1; transform: translateY(0); }

  @media (max-width: 1200px) { :global(.flavour-grid) { grid-template-columns: repeat(4, 1fr); } }
  @media (max-width: 900px)  { :global(.flavour-grid) { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 700px)  {
    .content { padding: 40px 20px 60px; }
    :global(.flavour-grid) { grid-template-columns: repeat(2, 1fr); }
  }
</style>

<script>
  var PID = 'dc8pwssq';
  var DS = 'production';
  var Q = encodeURIComponent('*[_type == "celsiusFlavour"] | order(name asc){name, "slug": slug.current, "img": image.asset->url, "color": image.asset->metadata.palette.vibrant.background}');
  var API = 'https://' + PID + '.api.sanity.io/v2024-01-01/data/query/' + DS + '?query=' + Q;

  function esc(s) { return s ? String(s) : ''; }

  function card(f) {
    var accent = f.color || '#e8e8e8';
    var inner =
      '<span class="flavour-tag">Skoða →</span>' +
      '<div class="flavour-accent" style="background:' + accent + '"></div>' +
      '<div class="flavour-photo">' +
        (f.img ? '<img src="' + f.img + '?w=500" alt="' + esc(f.name) + '">' : '') +
      '</div>' +
      '<div class="flavour-meta">' +
        '<div class="flavour-name">' + esc(f.name) + '</div>' +
      '</div>';
    if (f.slug) {
      return '<a class="flavour-card" href="/celsius-sida?slug=' + f.slug + '">' + inner + '</a>';
    }
    return '<div class="flavour-card">' + inner + '</div>';
  }

  fetch(API)
    .then(function(r) { return r.json(); })
    .then(function(data) {
      var flavours = data.result || [];
      var root = document.getElementById('flavours-root');
      root.innerHTML = flavours.length
        ? flavours.map(card).join('')
        : '<p class="empty-note">Engar bragðtegundir skráðar ennþá.</p>';
    });
</script>