---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Hljóðver">
  <div class="page-hero">
    <div class="page-hero-left">
      <div class="eyebrow">Hönnun & framleiðsla</div>
      <h1>Hljóðver</h1>
    </div>
    <div class="page-hero-right">
      <p>Myndform hefur talsett margar af vinsælustu teiknimyndum síðustu ára og rekur tvö fullbúin hljóðver. Hvort sem þú vilt talsetja efni, taka upp eða leigja hljóðver — við erum klár.</p>
      <a href="mailto:myndform@myndform.is?subject=Fyrirspurn%20um%20hlj%C3%B3%C3%B0ver" class="cta-btn">Hljóðver til leigu — hafðu samband</a>
    </div>
  </div>

  <div class="content">

    <!-- ── TALSETNING (leads) ── -->
    <div class="section-intro">
      <div class="eyebrow-red">Talsetning</div>
      <h2>Íslenskar raddir í uppáhaldsmyndunum</h2>
      <p>Mikill fjöldi erlendra teiknimynda hefur verið talsettur hjá Myndform. Í samvinnu við framúrskarandi leikstjóra og stórskotalið íslenskra leikara höfum við tryggt að íslensk tunga sé alltaf til boða í skemmtiefni fyrir ungviði landsins.</p>
    </div>
    <div id="dubbed-root" class="dubbed-grid"><p class="loading">Sæki myndir…</p></div>

    <div class="divider"></div>

    <!-- ── STUDIO ── -->
    <div class="section-intro">
      <div class="eyebrow-red">Hljóðverin okkar</div>
      <h2>Tvö fullbúin hljóðver</h2>
      <p>Árið 2011 var útbúið fullkomið hljóðver og árið 2016 bættist annað við. Hljóðverin eru til leigu með nýjasta búnaði til upptöku, blöndunar og masteringar — og við getum aðstoðað við framleiðsluna.</p>
    </div>
    <div id="studio-root" class="studio-grid"><p class="loading">Sæki myndir…</p></div>

    <!-- ── SERVICES ── -->
    <div class="feature-grid">
      <div class="feature-card">
        <div class="feature-name">Upptökur</div>
        <div class="feature-desc">Raddir, þættir, auglýsingar og kvikmyndir — við tökum við öllum verkefnum.</div>
      </div>
      <div class="feature-card">
        <div class="feature-name">Blöndun & meðhöndlun</div>
        <div class="feature-desc">Fagleg hljóðblöndun og mastering fyrir hvaða miðil sem er.</div>
      </div>
      <div class="feature-card">
        <div class="feature-name">Kvikmyndahljóð</div>
        <div class="feature-desc">Hljóðlausnir sérstaklega fyrir kvikmyndir og sjónvarpsefni.</div>
      </div>
      <div class="feature-card">
        <div class="feature-name">Útvarp & podcast</div>
        <div class="feature-desc">Tækni og aðstaða fyrir útvarpsefni og hlaðvarp í hæsta gæðaflokki.</div>
      </div>
    </div>

  </div>

  <div class="cta-strip">
    <div>
      <div class="cta-strip-title">Langar þig að bóka tíma?</div>
      <div class="cta-strip-sub">Hafðu samband og við finnum tíma sem hentar.</div>
    </div>
    <a href="mailto:myndform@myndform.is" class="cta-btn-red">Hafðu samband</a>
  </div>
</Layout>

<style>
  .page-hero {
    background: #1a1a1d;
    padding: 56px 32px;
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 48px; align-items: center;
  }
  .eyebrow {
    font-size: 11px; font-weight: 600; letter-spacing: 0.1em;
    text-transform: uppercase; color: #ff5a5a; margin-bottom: 12px;
  }
  h1 {
    font-size: 44px; font-weight: 700; color: var(--white);
    line-height: 1.05; letter-spacing: -0.02em;
  }
  .page-hero-right p {
    font-size: 14px; color: rgba(255,255,255,0.85);
    line-height: 1.75; margin-bottom: 24px;
  }
  .cta-btn {
    display: inline-block;
    border: 2px solid rgba(255,255,255,0.85); color: var(--white);
    background: transparent; padding: 11px 22px; border-radius: 3px;
    font-size: 12px; font-weight: 600; letter-spacing: 0.1em;
    text-transform: uppercase; text-decoration: none;
    transition: background 0.15s;
  }
  .cta-btn:hover { background: rgba(255,255,255,0.15); }

  .content { padding: 48px 32px; }
  .loading { font-size: 14px; color: var(--gray-60); }

  .section-intro { margin-bottom: 28px; max-width: 720px; }
  .eyebrow-red {
    font-size: 11px; font-weight: 600; letter-spacing: 0.1em;
    text-transform: uppercase; color: var(--red); margin-bottom: 10px;
  }
  h2 {
    font-size: 26px; font-weight: 700; letter-spacing: -0.01em;
    margin-bottom: 14px;
  }
  .section-intro p { font-size: 14px; color: var(--gray-60); line-height: 1.75; }

  /* Injected by the script, so :global() lets the styles reach it. */

  .content :global(.dubbed-grid) {
    display: grid; grid-template-columns: repeat(6, 1fr); gap: 16px;
    margin-bottom: 8px;
  }
  .content :global(.dubbed-card) {
    border-radius: 8px; overflow: hidden; background: #1a1a1a;
    aspect-ratio: 2/3; position: relative;
    border: 0.5px solid var(--gray-20);
  }
  .content :global(.dubbed-card img) {
    width: 100%; height: 100%; object-fit: cover; display: block;
  }
  .content :global(.dubbed-title) {
    position: absolute; left: 0; right: 0; bottom: 0;
    padding: 24px 12px 12px;
    background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, transparent 100%);
    font-size: 12px; font-weight: 600; color: #fff;
  }

  .content :global(.studio-grid) {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px;
    margin-bottom: 8px;
  }
  .content :global(.studio-card) {
    border-radius: 8px; overflow: hidden; background: #1a1a1a;
    aspect-ratio: 4/3; position: relative;
  }
  .content :global(.studio-card img) {
    width: 100%; height: 100%; object-fit: cover; display: block;
  }
  .content :global(.studio-caption) {
    position: absolute; left: 0; right: 0; bottom: 0;
    padding: 28px 14px 12px;
    background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 100%);
    font-size: 11px; font-weight: 600; color: #fff;
    letter-spacing: 0.05em; text-transform: uppercase;
    opacity: 0; transition: opacity 0.2s;
  }
  .content :global(.studio-card:hover .studio-caption) { opacity: 1; }

  .divider { height: 1px; background: var(--gray-20); margin: 48px 0; }

  .feature-grid {
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: 16px; margin-top: 48px;
  }
  .feature-card {
    background: var(--gray-10);
    border-radius: 8px; padding: 24px;
    border-left: 3px solid var(--red);
  }
  .feature-name { font-size: 14px; font-weight: 600; margin-bottom: 8px; }
  .feature-desc { font-size: 13px; color: var(--gray-60); line-height: 1.6; }

  .cta-strip {
    margin: 48px 32px;
    background: var(--gray-10); border-radius: 8px;
    padding: 28px 32px;
    display: flex; align-items: center;
    justify-content: space-between; gap: 24px;
  }
  .cta-strip-title { font-size: 17px; font-weight: 600; margin-bottom: 4px; }
  .cta-strip-sub { font-size: 13px; color: var(--gray-60); }
  .cta-btn-red {
    display: inline-block;
    border: 2px solid var(--red); color: var(--red);
    background: transparent; padding: 11px 22px; border-radius: 3px;
    font-size: 12px; font-weight: 600; letter-spacing: 0.1em;
    text-transform: uppercase; text-decoration: none; white-space: nowrap;
    transition: background 0.15s, color 0.15s;
  }
  .cta-btn-red:hover { background: var(--red); color: var(--white); }

  @media (max-width: 1100px) {
    .content :global(.dubbed-grid) { grid-template-columns: repeat(5, 1fr); }
  }
  @media (max-width: 900px) {
    .content :global(.dubbed-grid) { grid-template-columns: repeat(4, 1fr); }
    .content :global(.studio-grid) { grid-template-columns: repeat(2, 1fr); }
    .feature-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 700px) {
    .page-hero { grid-template-columns: 1fr; padding: 48px 20px; }
    h1 { font-size: 32px; }
    .content { padding: 40px 20px; }
    .content :global(.dubbed-grid) { grid-template-columns: repeat(3, 1fr); }
    .cta-strip { flex-direction: column; align-items: flex-start; margin: 32px 20px; }
  }
</style>

<script>
  var PID = 'dc8pwssq';
  var DS = 'production';
  var Q = encodeURIComponent('{"dubbed": *[_type == "dubbedFilm"] | order(_createdAt asc){title, poster}, "photos": *[_type == "studioPhoto"] | order(_createdAt asc){caption, image}}');
  var API = 'https://' + PID + '.api.sanity.io/v2024-01-01/data/query/' + DS + '?query=' + Q;

  function imgUrl(ref, w, h) {
    var id = ref.asset._ref.replace('image-', '').replace(/-([a-z]+)$/, '.$1');
    var url = 'https://cdn.sanity.io/images/' + PID + '/' + DS + '/' + id + '?w=' + w;
    if (h) url += '&h=' + h + '&fit=crop';
    return url;
  }
  function esc(s) { return s ? String(s) : ''; }

  function dubbedCard(f) {
    return '<div class="dubbed-card">' +
      (f.poster ? '<img src="' + imgUrl(f.poster, 400, 600) + '" alt="' + esc(f.title) + '">' : '') +
      '<div class="dubbed-title">' + esc(f.title) + '</div>' +
    '</div>';
  }
  function studioCard(p) {
    return '<div class="studio-card">' +
      (p.image ? '<img src="' + imgUrl(p.image, 600, 450) + '" alt="' + esc(p.caption) + '">' : '') +
      (p.caption ? '<div class="studio-caption">' + esc(p.caption) + '</div>' : '') +
    '</div>';
  }

  fetch(API)
    .then(function(r) { return r.json(); })
    .then(function(data) {
      var d = data.result || {};
      var dubbed = d.dubbed || [];
      var photos = d.photos || [];

      var dr = document.getElementById('dubbed-root');
      dr.innerHTML = dubbed.length
        ? dubbed.map(dubbedCard).join('')
        : '<p class="loading">Engar talsettar myndir skráðar ennþá.</p>';

      var sr = document.getElementById('studio-root');
      sr.innerHTML = photos.length
        ? photos.map(studioCard).join('')
        : '<p class="loading">Engar hljóðversmyndir skráðar ennþá.</p>';
    });
</script>