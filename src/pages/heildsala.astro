---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Heildsala">
  <div class="heildsala-page">
    <div class="site-hero">
      <div class="site-hero-eyebrow">Myndform</div>
      <h1>Heildsala</h1>
      <div class="site-hero-actions">
        <a href="mailto:myndform@myndform.is" class="site-hero-btn">Gerast viðskiptavinur</a>
      </div>
    </div>

    <div class="content">
      <p class="page-intro">Við dreifum og seljum á heildsöluverði til verslana og fyrirtækja um allt land — borðspil, leikföng, mat- og drykkjarvörur. Hafðu samband til að gerast viðskiptavinur.</p>
      <div id="catalog-root">
        <p class="loading">Sæki vörur…</p>
      </div>
    </div>

    <div class="cta-strip-wrap">
      <div class="cta-strip">
        <div>
          <div class="cta-strip-title">Hefur þú áhuga á að selja vörur okkar?</div>
          <div class="cta-strip-sub">Við tökum alltaf á móti nýjum viðskiptavinum — hafðu samband.</div>
        </div>
        <a href="mailto:myndform@myndform.is" class="cta-btn-red">Hafðu samband</a>
      </div>
    </div>
  </div>
</Layout>

<style>
  .heildsala-page { padding-bottom: 0; }

  .page-intro {
    font-size: 23px; color: var(--black); line-height: 1.5;
    max-width: 720px; margin: 0 0 44px;
    font-weight: 500; letter-spacing: -0.01em;
    padding-left: 22px; border-left: 3px solid var(--red);
  }

  .content { max-width: none; margin: 0; padding: 52px 48px; }
  .loading { font-size: 14px; color: var(--gray-60); }

  /* Injected by the script, so :global() lets the styles reach it. */

  .content :global(.category-block) { margin-bottom: 52px; }
  .content :global(.category-block:last-child) { margin-bottom: 0; }
  .content :global(.category-title) {
    font-size: 11px; font-weight: 600; letter-spacing: 0.1em;
    text-transform: uppercase; color: #aaa; margin-bottom: 20px;
    padding-bottom: 14px; border-bottom: 1px solid var(--gray-20);
  }

  .content :global(.bordspil-banner) {
    display: flex; align-items: center; justify-content: space-between; gap: 32px;
    text-decoration: none; color: inherit;
    background: var(--gray-10); border-radius: 14px;
    padding: 28px 32px; transition: transform 0.15s, box-shadow 0.15s;
  }
  .content :global(.bordspil-banner:hover) {
    transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.06);
  }
  .content :global(.banner-title) { font-size: 20px; font-weight: 700; margin-bottom: 6px; }
  .content :global(.banner-sub) { font-size: 14px; color: var(--gray-60); line-height: 1.5; margin-bottom: 12px; }
  .content :global(.banner-link) { font-size: 13px; font-weight: 600; color: var(--red); }
  .content :global(.banner-thumbs) { display: flex; gap: 12px; flex-shrink: 0; }
  .content :global(.banner-thumb) {
    width: 84px; height: 84px; background: #fff; border: 1px solid var(--gray-20);
    border-radius: 10px; display: flex; align-items: center; justify-content: center; padding: 10px;
  }
  .content :global(.banner-thumb img) { max-width: 100%; max-height: 100%; object-fit: contain; }

  .content :global(.brand-grid) { display: grid; grid-template-columns: repeat(6, 1fr); gap: 20px; }
  .content :global(.brand-card) {
    display: flex; flex-direction: column;
    text-decoration: none; color: inherit;
    border: 1px solid var(--gray-20); border-radius: 12px;
    overflow: hidden; background: var(--white);
    transition: border-color 0.15s, transform 0.15s, box-shadow 0.15s;
  }
  .content :global(.brand-card:hover) {
    border-color: var(--gray-60); transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,0.06);
  }
  .content :global(.brand-logo-wrap) {
    aspect-ratio: 3/2; background: var(--gray-10);
    display: flex; align-items: center; justify-content: center; padding: 30px;
  }
  .content :global(.brand-logo-wrap img) { max-width: 100%; max-height: 100%; object-fit: contain; display: block; }
  .content :global(.brand-meta) { padding: 16px 18px 18px; }
  .content :global(.brand-name) { font-size: 15px; font-weight: 600; margin-bottom: 4px; }
  .content :global(.brand-tagline) { font-size: 12px; color: var(--gray-60); line-height: 1.45; }

  .cta-strip-wrap { max-width: none; margin: 0; padding: 0 48px 64px; }
  .cta-strip {
    background: var(--gray-10); border-radius: 12px; padding: 30px 34px;
    display: flex; align-items: center; justify-content: space-between; gap: 24px;
  }
  .cta-strip-title { font-size: 18px; font-weight: 600; margin-bottom: 4px; }
  .cta-strip-sub { font-size: 13px; color: var(--gray-60); }
  .cta-btn-red {
    display: inline-block;
    border: 2px solid var(--red); color: var(--red);
    background: transparent; padding: 12px 24px; border-radius: 4px;
    font-size: 12px; font-weight: 600; letter-spacing: 0.1em;
    text-transform: uppercase; text-decoration: none; white-space: nowrap;
    transition: background 0.15s, color 0.15s;
  }
  .cta-btn-red:hover { background: var(--red); color: var(--white); }

  @media (max-width: 1500px) { .content :global(.brand-grid) { grid-template-columns: repeat(5, 1fr); } }
  @media (max-width: 1200px) { .content :global(.brand-grid) { grid-template-columns: repeat(4, 1fr); } }
  @media (max-width: 1000px) {
    .content :global(.brand-grid) { grid-template-columns: repeat(3, 1fr); }
    .content :global(.banner-thumbs) { display: none; }
  }
  @media (max-width: 700px) {
    .content, .cta-strip-wrap { padding-left: 20px; padding-right: 20px; }
    .content :global(.brand-grid) { grid-template-columns: repeat(2, 1fr); }
    .content :global(.bordspil-banner) { flex-direction: column; align-items: flex-start; }
    .cta-strip { flex-direction: column; align-items: flex-start; }
  }
</style>

<script>
  var PID = 'dc8pwssq';
  var DS = 'production';
  var Q = encodeURIComponent('{"brands": *[_type == "brand"] | order(name asc), "games": *[_type == "boardgame"] | order(name asc)}');
  var API = 'https://' + PID + '.api.sanity.io/v2024-01-01/data/query/' + DS + '?query=' + Q;

  function imgUrl(ref, w) {
    var id = ref.asset._ref.replace('image-', '').replace(/-([a-z]+)$/, '.$1');
    return 'https://cdn.sanity.io/images/' + PID + '/' + DS + '/' + id + '?w=' + w;
  }
  function esc(s) { return s ? String(s) : ''; }

  function brandCard(b) {
    return '<a class="brand-card" href="/vara?slug=' + b.slug.current + '">' +
      '<div class="brand-logo-wrap">' +
        (b.logo ? '<img src="' + imgUrl(b.logo, 400) + '" alt="' + esc(b.name) + '">' : '') +
      '</div>' +
      '<div class="brand-meta">' +
        '<div class="brand-name">' + esc(b.name) + '</div>' +
        (b.tagline ? '<div class="brand-tagline">' + esc(b.tagline) + '</div>' : '') +
      '</div>' +
    '</a>';
  }

  fetch(API)
    .then(function(r) { return r.json(); })
    .then(function(data) {
      var res = data.result || {};
      var brands = res.brands || [];
      var games = res.games || [];
      var root = document.getElementById('catalog-root');
      var html = '';

      if (games.length) {
        var thumbs = games.slice(0, 4).map(function(g) {
          return '<div class="banner-thumb">' +
            (g.image ? '<img src="' + imgUrl(g.image, 200) + '" alt="' + esc(g.name) + '">' : '') +
          '</div>';
        }).join('');
        html += '<div class="category-block">' +
          '<div class="category-title">Borðspil</div>' +
          '<a class="bordspil-banner" href="/bordspil">' +
            '<div class="banner-text">' +
              '<div class="banner-title">' + games.length + ' borðspil frá ýmsum framleiðendum</div>' +
              '<div class="banner-sub">Fjölbreytt úrval fyrir alla aldurshópa — partýspil, fjölskylduspil og barnaspil.</div>' +
              '<span class="banner-link">Skoða öll borðspil →</span>' +
            '</div>' +
            '<div class="banner-thumbs">' + thumbs + '</div>' +
          '</a>' +
        '</div>';
      }

      var toys = brands.filter(function(b) { return b.category === 'leikfong'; });
      if (toys.length) {
        html += '<div class="category-block">' +
          '<div class="category-title">Leikföng</div>' +
          '<div class="brand-grid">' + toys.map(brandCard).join('') + '</div>' +
        '</div>';
      }

      var food = brands.filter(function(b) { return b.category === 'matvara'; });
      if (food.length) {
        html += '<div class="category-block">' +
          '<div class="category-title">Mat- og drykkjarvörur</div>' +
          '<div class="brand-grid">' + food.map(brandCard).join('') + '</div>' +
        '</div>';
      }

      root.innerHTML = html || '<p class="loading">Engar vörur skráðar ennþá.</p>';
    });
</script>