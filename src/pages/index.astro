---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Forsíða">
  <div class="home-hero">
    <div class="home-hero-left">
      <div class="home-hero-eyebrow">Kvikmyndadreifing & þjónusta</div>
      <h1>Við komum<br>myndunum<br><span>í bíó.</span></h1>
    </div>
    <div class="home-hero-right">
      <p>Myndform hefur starfað við kvikmyndadreifingu, hönnun, prentun og heildsölu í áratugi. Við þjónum kvikmyndahúsum, smásöluaðilum og auglýsendum um allt land.</p>
      <div class="home-services">
        <a href="/films" class="service-card">
          <div class="service-name">Kvikmyndadreifing</div>
          <div class="service-desc">Dreifing á erlendum og innlendum myndum</div>
        </a>
        <a href="/portfolio" class="service-card">
          <div class="service-name">Auglýsingahönnun</div>
          <div class="service-desc">Hönnun og framleiðsla auglýsinga</div>
        </a>
        <a href="/prentun" class="service-card">
          <div class="service-name">Prentun</div>
          <div class="service-desc">Bílamerkingar, skilt og prentverkefni</div>
        </a>
        <a href="/heildsala" class="service-card">
          <div class="service-name">Heildsala</div>
          <div class="service-desc">Borðspil, leikföng og matvörur</div>
        </a>
      </div>
    </div>
  </div>

  <div class="film-section">
    <div class="film-block reveal">
      <div class="block-head">
        <div>
          <div class="block-eyebrow">Í bíó núna</div>
          <h2>Sýndar í kvikmyndahúsum</h2>
        </div>
        <a href="/films" class="see-all">Sjá allar →</a>
      </div>
      <div class="home-film-grid" id="grid-now"><p class="loading">Sæki myndir…</p></div>
    </div>

    <div class="film-block reveal">
      <div class="block-head">
        <div>
          <div class="block-eyebrow">Væntanlegt</div>
          <h2>Næstu frumsýningar</h2>
        </div>
        <a href="/films" class="see-all">Sjá allar →</a>
      </div>
      <div class="home-film-grid" id="grid-soon"><p class="loading">Sæki myndir…</p></div>
    </div>
  </div>

  <div class="cred-band">
    <div class="cred-item"><div class="cred-num">1984</div><div class="cred-label">Starfað síðan</div></div>
    <div class="cred-sep"></div>
    <div class="cred-item"><div class="cred-num">2</div><div class="cred-label">Hljóðver</div></div>
    <div class="cred-sep"></div>
    <div class="cred-item"><div class="cred-num">4</div><div class="cred-label">Þjónustusvið</div></div>
    <div class="cred-sep"></div>
    <div class="cred-item"><div class="cred-num">Allt land</div><div class="cred-label">Þjónustusvæði</div></div>
  </div>
</Layout>

<style>
  .home-hero {
    background: #1a1a1d;
    color: var(--white);
    padding: 72px 48px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
  }
  .home-hero-eyebrow {
    font-size: 11px; font-weight: 600; letter-spacing: 0.12em;
    text-transform: uppercase; color: #ff5a5a; margin-bottom: 16px;
  }
  h1 {
    font-size: 52px; font-weight: 700; line-height: 1.05;
    letter-spacing: -0.02em; color: var(--white); margin-bottom: 0;
  }
  h1 span { color: var(--red); }
  .home-hero-right p {
    font-size: 16px; color: rgba(255,255,255,0.65);
    line-height: 1.75; margin-bottom: 32px;
  }
  .home-services {
    display: grid; grid-template-columns: 1fr 1fr; gap: 12px;
  }
  .service-card {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-left: 3px solid var(--red);
    border-radius: 0 8px 8px 0;
    padding: 16px 18px;
    text-decoration: none;
    color: inherit;
    display: block;
    transition: background 0.18s ease, border-color 0.18s ease, transform 0.18s ease;
  }
  .service-card:hover {
    background: rgba(255,255,255,0.1);
    border-color: rgba(255,255,255,0.2);
    border-left-color: var(--red);
    transform: translateY(-3px);
  }
  .service-name { font-size: 14px; font-weight: 500; color: var(--white); margin-bottom: 5px; }
  .service-desc { font-size: 12px; color: rgba(255,255,255,0.45); line-height: 1.5; }

  .film-section { padding: 56px 48px 16px; }
  .film-block { margin-bottom: 48px; }
  .block-head {
    display: flex; justify-content: space-between; align-items: flex-end;
    margin-bottom: 22px;
  }
  .block-eyebrow {
    font-size: 11px; font-weight: 600; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--red); margin-bottom: 8px;
  }
  h2 { font-size: 24px; font-weight: 700; letter-spacing: -0.01em; color: #111; }
  .see-all {
    font-size: 13px; color: var(--gray-60); text-decoration: none;
    white-space: nowrap; transition: color 0.15s;
  }
  .see-all:hover { color: var(--red); }
  .loading { font-size: 14px; color: var(--gray-60); }

  /* Injected by the script, so :global() lets the styles reach it. */

  :global(.home-film-grid) { display: grid; grid-template-columns: repeat(6, 1fr); gap: 18px; }
  :global(.home-film-grid .empty-note) {
    font-size: 14px; color: var(--gray-60); grid-column: 1 / -1;
  }
  :global(.home-film-grid .film-card) {
    display: block; text-decoration: none; color: inherit; min-width: 0;
  }
  :global(.home-film-grid .poster-wrap) {
    width: 100%; aspect-ratio: 2/3; border-radius: 8px;
    overflow: hidden; background: #1a1a1a; margin-bottom: 10px;
    position: relative;
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }
  :global(.home-film-grid a.film-card:hover .poster-wrap) {
    transform: translateY(-4px);
    box-shadow: 0 10px 26px rgba(0,0,0,0.18);
  }
  :global(.home-film-grid .poster-wrap img) {
    position: absolute; inset: 0; width: 100%; height: 100%;
    object-fit: cover; object-position: center; display: block;
  }
  :global(.home-film-grid .film-title) {
    font-size: 13px; font-weight: 600; line-height: 1.3; color: #111; margin-bottom: 2px;
  }
  :global(.home-film-grid .film-date) { font-size: 12px; color: var(--red); font-weight: 500; }

  .cred-band {
    background: #1a1a1d; margin: 16px 48px 64px; border-radius: 12px;
    padding: 32px 40px;
    display: flex; justify-content: space-around; align-items: center;
    flex-wrap: wrap; gap: 24px;
  }
  .cred-item { text-align: center; }
  .cred-num { font-size: 28px; font-weight: 700; color: #fff; letter-spacing: -0.01em; }
  .cred-label {
    font-size: 11px; color: rgba(255,255,255,0.5);
    text-transform: uppercase; letter-spacing: 0.07em; margin-top: 5px;
  }
  .cred-sep { width: 1px; height: 42px; background: rgba(255,255,255,0.15); }

  .reveal { opacity: 0; transform: translateY(18px); transition: opacity 0.6s ease, transform 0.6s ease; }
  .reveal.in { opacity: 1; transform: translateY(0); }

  @media (max-width: 1100px) { :global(.home-film-grid) { grid-template-columns: repeat(5, 1fr); } }
  @media (max-width: 900px) {
    :global(.home-film-grid) { grid-template-columns: repeat(4, 1fr); }
    .cred-sep { display: none; }
  }
  @media (max-width: 700px) {
    .home-hero { grid-template-columns: 1fr; padding: 48px 20px; gap: 32px; }
    h1 { font-size: 36px; }
    .home-services { grid-template-columns: 1fr; }
    .film-section { padding: 40px 20px 8px; }
    :global(.home-film-grid) { grid-template-columns: repeat(3, 1fr); }
    .cred-band { margin: 8px 20px 40px; padding: 24px; gap: 20px; }
  }
</style>

<script>
  var PID = 'dc8pwssq';
  var DS = 'production';
  var Q = encodeURIComponent('*[_type == "film"] | order(releaseDate asc){title, status, releaseDate, poster, "slug": slug.current}');
  var API = 'https://' + PID + '.api.sanity.io/v2024-01-01/data/query/' + DS + '?query=' + Q;

  function imgUrl(ref) {
    var id = ref.asset._ref.replace('image-', '').replace(/-([a-z]+)$/, '.$1');
    return 'https://cdn.sanity.io/images/' + PID + '/' + DS + '/' + id + '?w=400';
  }
  function esc(s) { return s ? String(s) : ''; }
  function fmtDate(s) {
    if (!s) return '';
    return new Date(s).toLocaleDateString('is-IS', {day:'numeric', month:'long', year:'numeric'});
  }

  function makeCard(film, showDate) {
    var inner =
      '<div class="poster-wrap">' +
        (film.poster ? '<img src="' + imgUrl(film.poster) + '" alt="' + esc(film.title) + '">' : '') +
      '</div>' +
      '<div class="film-title">' + esc(film.title) + '</div>' +
      (showDate ? '<div class="film-date">' + fmtDate(film.releaseDate) + '</div>' : '');
    if (film.slug) {
      return '<a class="film-card" href="/kvikmynd?slug=' + film.slug + '">' + inner + '</a>';
    }
    return '<div class="film-card">' + inner + '</div>';
  }

  fetch(API)
    .then(function(r) { return r.json(); })
    .then(function(data) {
      var films = data.result || [];
      var now = films.filter(function(f){ return f.status === 'now'; }).slice(0, 6);
      var soon = films.filter(function(f){ return f.status === 'soon'; }).slice(0, 6);

      var gNow = document.getElementById('grid-now');
      gNow.innerHTML = now.length
        ? now.map(function(f){ return makeCard(f, false); }).join('')
        : '<p class="empty-note">Engar myndir í sýningu núna.</p>';

      var gSoon = document.getElementById('grid-soon');
      gSoon.innerHTML = soon.length
        ? soon.map(function(f){ return makeCard(f, true); }).join('')
        : '<p class="empty-note">Engar væntanlegar myndir skráðar.</p>';
    });

  var io = new IntersectionObserver(function(entries) {
    entries.forEach(function(e) {
      if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
    });
  }, { threshold: 0.12 });
  document.querySelectorAll('.reveal').forEach(function(el){ io.observe(el); });
</script>