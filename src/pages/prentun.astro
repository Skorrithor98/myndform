---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Prentun">
  <div class="page-hero">
    <div class="page-hero-left">
      <div class="eyebrow">Hönnun & framleiðsla</div>
      <h1>Prentun</h1>
    </div>
    <div class="page-hero-right">
      <p>Við bjóðum upp á fjölbreytta prentþjónustu — frá bílamerkingum og innréttingafilmum til skiltagerðar og stórra prentverkefna. Við sjáum um allt frá hönnun til fullunninnar framleiðslu.</p>
      <a href="mailto:myndform@myndform.is" class="cta-btn">Hafðu samband</a>
    </div>
  </div>

  <div class="content">
    <div class="feature-grid">
      <div class="feature-card">
        <div class="feature-name">Bílamerkingar</div>
        <div class="feature-desc">Fagleg bílamerkingar fyrir einstaklinga og fyrirtæki — allt að fullri þekju.</div>
      </div>
      <div class="feature-card">
        <div class="feature-name">Innréttingafilmur</div>
        <div class="feature-desc">Glugga- og veggfilmur fyrir skrifstofur, verslanir og aðrar byggingar.</div>
      </div>
      <div class="feature-card">
        <div class="feature-name">Skiltagerð</div>
        <div class="feature-desc">Úti- og inniskilt, bannerskilt, kynningarskilt og fleira.</div>
      </div>
      <div class="feature-card">
        <div class="feature-name">Stór prentverkefni</div>
        <div class="feature-desc">Veggpóstur, kynningarefni, bæklingar og önnur stór prentverkefni.</div>
      </div>
    </div>

    <div class="portfolio-row two">
      <div class="item tall bg-dark">
        <div class="item-label">Bílamerkingar</div>
      </div>
      <div class="item tall bg-mid">
        <div class="item-label">Skiltagerð</div>
      </div>
    </div>
    <div class="portfolio-row four">
      <div class="item sq bg-warm">
        <div class="item-label">Innréttingafilmur</div>
      </div>
      <div class="item sq bg-slate">
        <div class="item-label">Veggpóstur</div>
      </div>
      <div class="item sq bg-light">
        <div class="item-label">Bæklingar</div>
      </div>
      <div class="item sq bg-red">
        <div class="item-label">Kynningarefni</div>
      </div>
    </div>
  </div>

  <div class="cta-strip">
    <div>
      <div class="cta-strip-title">Ertu með prentverkefni í huga?</div>
      <div class="cta-strip-sub">Hafðu samband og við metum verkefnið og gefum tilboð.</div>
    </div>
    <a href="mailto:myndform@myndform.is" class="cta-btn-red">Hafðu samband</a>
  </div>
</Layout>

<style>
  .page-hero {
    background: #1a1a1d;
    padding: 56px 32px;
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 48px; align-items: center;
  }
  .eyebrow {
    font-size: 11px; font-weight: 600; letter-spacing: 0.1em;
    text-transform: uppercase; color: #ff5a5a; margin-bottom: 12px;
  }
  h1 {
    font-size: 44px; font-weight: 700; color: var(--white);
    line-height: 1.05; letter-spacing: -0.02em;
  }
  .page-hero-right p {
    font-size: 14px; color: rgba(255,255,255,0.85);
    line-height: 1.75; margin-bottom: 24px;
  }
  .cta-btn {
    display: inline-block;
    border: 2px solid rgba(255,255,255,0.85); color: var(--white);
    background: transparent; padding: 11px 22px; border-radius: 3px;
    font-size: 12px; font-weight: 600; letter-spacing: 0.1em;
    text-transform: uppercase; text-decoration: none;
    transition: background 0.15s;
  }
  .cta-btn:hover { background: rgba(255,255,255,0.15); }

  .content { padding: 48px 32px; }

  .feature-grid {
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: 16px; margin-bottom: 32px;
  }
  .feature-card {
    background: var(--gray-10);
    border-radius: 8px; padding: 24px;
    border-left: 3px solid var(--red);
  }
  .feature-name { font-size: 14px; font-weight: 600; margin-bottom: 8px; }
  .feature-desc { font-size: 13px; color: var(--gray-60); line-height: 1.6; }

  .portfolio-row { display: grid; gap: 8px; margin-bottom: 8px; }
  .portfolio-row.two { grid-template-columns: 1fr 1fr; }
  .portfolio-row.four { grid-template-columns: repeat(4, 1fr); }

  .item {
    border-radius: 4px; overflow: hidden;
    position: relative; cursor: pointer;
  }
  .item.tall { aspect-ratio: 4/3; }
  .item.sq { aspect-ratio: 1/1; }
  .item-label {
    position: absolute; bottom: 0; left: 0; right: 0;
    padding: 14px;
    background: linear-gradient(to top, rgba(0,0,0,0.55) 0%, transparent 100%);
    font-size: 11px; font-weight: 600; color: #fff;
    letter-spacing: 0.07em; text-transform: uppercase;
    opacity: 0; transition: opacity 0.2s;
  }
  .item:hover .item-label { opacity: 1; }

  .bg-dark { background: #1a1a1a; }
  .bg-mid { background: #aaaaaa; }
  .bg-warm { background: #c0a898; }
  .bg-red { background: #c01010; }
  .bg-slate { background: #8898aa; }
  .bg-light { background: #d0ccc8; }

  .cta-strip {
    margin: 40px 32px 48px;
    background: var(--gray-10); border-radius: 8px;
    padding: 28px 32px;
    display: flex; align-items: center;
    justify-content: space-between; gap: 24px;
  }
  .cta-strip-title { font-size: 17px; font-weight: 600; margin-bottom: 4px; }
  .cta-strip-sub { font-size: 13px; color: var(--gray-60); }
  .cta-btn-red {
    display: inline-block;
    border: 2px solid var(--red); color: var(--red);
    background: transparent; padding: 11px 22px; border-radius: 3px;
    font-size: 12px; font-weight: 600; letter-spacing: 0.1em;
    text-transform: uppercase; text-decoration: none; white-space: nowrap;
    transition: background 0.15s, color 0.15s;
  }
  .cta-btn-red:hover { background: var(--red); color: var(--white); }

  @media (max-width: 700px) {
    .page-hero { grid-template-columns: 1fr; padding: 48px 20px; }
    h1 { font-size: 32px; }
    .feature-grid { grid-template-columns: repeat(2, 1fr); }
    .portfolio-row.four { grid-template-columns: repeat(2, 1fr); }
    .cta-strip { flex-direction: column; align-items: flex-start; margin: 32px 20px; }
  }
</style>