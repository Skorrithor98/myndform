---
const { title } = Astro.props;
---

<html lang="is">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · Myndform</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style is:global>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --red: #e02020;
        --red-dark: #b81010;
        --black: #111111;
        --gray-60: #666666;
        --gray-20: #e8e8e8;
        --gray-10: #f5f5f5;
        --white: #ffffff;
        --font: 'Inter', system-ui, sans-serif;
      }

      body {
  font-family: var(--font);
  color: var(--black);
  background: var(--white);
  -webkit-font-smoothing: antialiased;
  overflow-x: hidden;
}

      /* ── NAV ── */
      nav {
        position: sticky; top: 0; z-index: 100;
        background: var(--white);
        border-bottom: 1px solid var(--gray-20);
        display: flex; align-items: center; justify-content: space-between;
        padding: 0 32px; height: 56px;
      }
      .nav-logo {
        text-decoration: none; display: flex; align-items: center;
      }
      .nav-logo img { height: 28px; width: auto; }

      .nav-links {
        display: flex; gap: 0; list-style: none; height: 100%;
        margin: 0 auto;
      }
      .nav-links > li {
        position: relative; height: 100%;
        display: flex; align-items: center;
      }
      .nav-links > li > a {
        font-size: 13px; color: var(--gray-60); text-decoration: none;
        letter-spacing: 0.03em; transition: color 0.15s;
        padding: 0 14px; height: 100%;
        display: flex; align-items: center;
        white-space: nowrap;
      }
      .nav-links > li > a:hover { color: var(--black); }

      /* ── HAMBURGER ── */
      .nav-hamburger {
        display: none;
        flex-direction: column; justify-content: center; gap: 5px;
        width: 40px; height: 40px;
        background: none; border: none; cursor: pointer; padding: 8px;
      }
      .nav-hamburger span {
        display: block; width: 22px; height: 1.5px;
        background: var(--black); transition: all 0.25s;
        transform-origin: center;
      }
      .nav-hamburger.open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
      .nav-hamburger.open span:nth-child(2) { opacity: 0; }
      .nav-hamburger.open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

      /* ── MOBILE MENU ── */
      .mobile-menu {
        display: none;
        position: fixed; top: 56px; left: 0; right: 0; bottom: 0;
        background: var(--white); z-index: 99;
        padding: 24px 24px;
        flex-direction: column;
        overflow-y: auto;
      }
      .mobile-menu {
  transform: translateY(-10px);
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease, transform 0.3s ease;
  display: flex;
}
.mobile-menu.open {
  transform: translateY(0);
  opacity: 1;
  pointer-events: all;
}
      .mobile-menu a {
        font-size: 20px; font-weight: 600;
        color: var(--black); text-decoration: none;
        padding: 14px 0; border-bottom: 1px solid var(--gray-20);
        transition: color 0.15s;
      }
      .mobile-menu a:hover { color: var(--red); }
      .mobile-menu-contact {
        margin-top: 24px;
      }
      .mobile-menu-contact a {
        font-size: 14px; font-weight: 400;
        color: var(--gray-60); border-bottom: none; padding: 4px 0;
      }

      /* ── FOOTER ── */
      footer {
        border-top: 1px solid var(--gray-20);
        padding: 24px 32px;
        display: flex; justify-content: space-between; align-items: center;
      }
      .footer-logo { display: block; }
      .footer-logo img { height: 28px; width: auto; }
      .footer-info { font-size: 12px; color: var(--gray-60); text-align: right; line-height: 1.7; }
      .footer-hours { font-size: 12px; color: var(--gray-60); }
      /* ── SMOOTH TRANSITIONS ── */
a { transition: color 0.2s ease; }

nav {
  transition: box-shadow 0.3s ease;
}
nav.scrolled {
  box-shadow: 0 4px 20px rgba(0,0,0,0.06);
  border-bottom-color: transparent;
}

.nav-links > li > a::after {
  content: ''; position: absolute; bottom: 0; left: 14px; right: 14px;
  height: 2px; background: var(--red);
  transform: scaleX(0); transition: transform 0.3s ease;
}
.nav-links > li > a:hover::after { transform: scaleX(1); }
      @media (max-width: 1024px) {
        nav { padding: 0 20px; }
        .nav-links { display: none; }
        .nav-hamburger { display: flex; }
        footer { flex-direction: column; gap: 12px; align-items: flex-start; }
        .footer-info { text-align: left; }
      }
    </style>
  </head>
  <body>
    <nav>
      <a class="nav-logo" href="/"><img src="/logo.png" alt="Myndform" /></a>
      <ul class="nav-links">
        <li><a href="/">Forsíða</a></li>
        <li><a href="/films">Kvikmyndadreifing</a></li>
        <li><a href="/portfolio">Auglýsingahönnun</a></li>
        <li><a href="/hljodver">Hljóðver</a></li>
        <li><a href="/yfirfaersla">Yfirfærsla</a></li>
        <li><a href="/prentun">Prentun</a></li>
        <li><a href="/heildsala">Heildsala</a></li>
        <li><a href="/celsius">Celsius</a></li>
        <li><a href="/um-okkur">Um okkur</a></li>
      </ul>
      <button class="nav-hamburger" id="hamburger" aria-label="Opna valmynd">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </nav>

    <div class="mobile-menu" id="mobile-menu">
      <a href="/">Forsíða</a>
      <a href="/films">Kvikmyndadreifing</a>
      <a href="/portfolio">Auglýsingahönnun</a>
      <a href="/hljodver">Hljóðver</a>
      <a href="/yfirfaersla">Yfirfærsla</a>
      <a href="/prentun">Prentun</a>
      <a href="/heildsala">Heildsala</a>
      <a href="/celsius">Celsius</a>
      <a href="/um-okkur">Um okkur</a>
      <div class="mobile-menu-contact">
        <a href="tel:+3545340400">+354 534 0400</a>
        <a href="mailto:myndform@myndform.is">myndform@myndform.is</a>
      </div>
    </div>

    <slot />

    <footer>
      <div class="footer-logo"><img src="/logo.png" alt="Myndform" /></div>
      <div class="footer-hours">Mán 09–16 · Þri–Fös 09–17 · Lokað um helgar</div>
      <div class="footer-info">
        Trönuhraun 1, 220 Hafnarfjörður<br />
        +354 534 0400 · myndform@myndform.is
      </div>
    </footer>

    <script>
      // Hamburger
      const hamburger = document.getElementById('hamburger');
      const mobileMenu = document.getElementById('mobile-menu');
      hamburger.addEventListener('click', () => {
        hamburger.classList.toggle('open');
        mobileMenu.classList.toggle('open');
        document.body.style.overflow = mobileMenu.classList.contains('open') ? 'hidden' : '';
      });
      document.querySelectorAll('.mobile-menu a').forEach(link => {
        link.addEventListener('click', () => {
          hamburger.classList.remove('open');
          mobileMenu.classList.remove('open');
          document.body.style.overflow = '';
        });
      });

      // Nav shadow on scroll
      window.addEventListener('scroll', () => {
        const nav = document.querySelector('nav');
        if (window.scrollY > 20) {
          nav.classList.add('scrolled');
        } else {
          nav.classList.remove('scrolled');
        }
      });
    </script>
  </body>
</html>